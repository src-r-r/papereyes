{
  "extends": "eslint:recommended",
  "env": {
    "es2021": true,
    "node": true,
    "jest": true
  },
  "globals": {
    "browser": "readonly",
    "document": "readonly",
    "window": "readonly",
    "self": "readonly",
    "NoiseUtils": "readonly"
  },
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "warn",
    "indent": ["error", 2],
    "quotes": ["error", "double"],
    "semi": ["error", "always"]
  }
}
