{
  "manifest_version": 3,
  "name": "PaperEyes",
  "version": "1.0.0",
  "description": "Apply a subtle paper texture overlay to web pages for a more comfortable reading experience",
  "author": "Jordan Hewitt <jordan@damngood.tech>",
  "homepage_url": "https://github.com/src-r-r/papereyes",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "scripts": ["src/background/background.js"]
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "PaperEyes - Toggle Paper Texture",
    "default_icon": {
      "16": "src/icons/icon16.png",
      "48": "src/icons/icon48.png",
      "128": "src/icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "src/options/options.html",
    "browser_style": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/lib/noise.js", "src/content/content.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "icons": {
    "16": "src/icons/icon16.png",
    "48": "src/icons/icon48.png",
    "128": "src/icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "{3c317a51-f7c7-4d63-8778-882da8a1deab}",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [],
        "userFields": {},
        "dataElements": [],
        "processingPurposes": []
      }
    }
  }
}
